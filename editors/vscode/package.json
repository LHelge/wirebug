{
  "name": "wirebug",
  "displayName": "Wirebug",
  "description": "Language support for the wirebug electrical schematic and wiring harness DSL (.wb)",
  "version": "0.1.0",
  "publisher": "wirebug",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "wirebug",
        "extensions": [
          ".wb"
        ],
        "aliases": [
          "Wirebug",
          "wirebug"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "wirebug",
        "scopeName": "source.wirebug",
        "path": "./syntaxes/wirebug.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Wirebug",
      "properties": {
        "wirebug.server.path": {
          "type": "string",
          "default": "",
          "description": "Path to the wirebug binary used as the language server. When empty, a build in the repo's target/ directory (development) or `wirebug` on PATH is used."
        },
        "wirebug.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the messages between VSCode and the wirebug language server."
        }
      }
    },
    "commands": [
      {
        "command": "wirebug.restartServer",
        "title": "Wirebug: Restart Language Server"
      }
    ]
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "check": "tsc --noEmit",
    "package": "npm run check && npm run compile && vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.0"
  }
}
