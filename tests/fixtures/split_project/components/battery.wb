component battery {
    component cell_pack {
        pub port hv_pos "HV+";
        pub port hv_neg "HV-";
    }

    cell_pack pack "Cells";

    connector hv "HV 2p" {
        pub port hv_pos "HV+" pin 1;
        pub port hv_neg "HV-" pin 2;
    }

    wire orange 50 [hv_pos, pack.hv_pos];
    wire orange 50 [hv_neg, pack.hv_neg];
}
