use battery  from "components/battery.wb"
use inverter from "components/inverter.wb"

component vehicle {
    battery  pack "Battery";
    inverter inv  "Inverter";

    wire orange 50 "HV+" [pack.hv_pos, inv.dc_pos];
    wire orange 50 "HV-" [pack.hv_neg, inv.dc_neg];
}

view schematic "System Overview" {
    grid 20;

    include pack at (6, 8) ports {
        east: hv_pos, hv_neg;
    };

    include inv at (26, 8) ports {
        west: dc_pos, dc_neg;
    };
}

view harness "Main Harness" {
    grid 20;

    include pack.hv at (4, 8);
    include inv.hv  at (28, 8);
}
