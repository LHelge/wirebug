// Combined On-Board Charger and DC-DC converter
// Self-powered from HV bus. Charges from 1-phase AC inlet.
// Provides 12V output to the vehicle electrical system.

use Can4p from "../connectors.wb";

component ObcDcdc {
    connector hv "HV DC 2p" {
        pub port dc_pos "DC+" pin 1;
        pub port dc_neg "DC-" pin 2;
    }

    connector ac "AC inlet 3p" {
        pub port ac_l  "AC L" pin 1;
        pub port ac_n  "AC N" pin 2;
        pub port ac_pe "AC PE" pin 3;
    }

    connector lv "12V output 4p" {
        pub port out_pos "12V OUT+" pins [1, 2];
        pub port out_neg "12V OUT-" pins [3, 4];
    }

    pub port can_h "CAN H";
    pub port can_l "CAN L";

    connector can: Can4p {
        pin 1: can_h;
        pin 2: can_l;
    }

    connector intlk "Interlock 2p" {
        pub port interlock_in  "INTLK IN" pin 1;
        pub port interlock_out "INTLK OUT" pin 2;
    }
}
